{
    "manifest_version": 3,
    "name": "VOID Ron OS 🔥",
    "description": "Futuristic hacker dashboard for Chrome with full control, quick access, and customization.",
    "version": "1.0",
    "icons": {
        "128": "icons/icon128.png"
    },
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "permissions": [
        "history",
        "bookmarks",
        "downloads",
        "storage"
    ],
    "background": {
        "service_worker": "background.js"
    }
}